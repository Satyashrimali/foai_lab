{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/hf-api/:path*",
      "destination": "https://api-inference.huggingface.co/:path*"
    },
    {
      "source": "/hf-inference/:path*",
      "destination": "https://api-inference.huggingface.co/:path*"
    },
    {
      "source": "/models/:path*",
      "destination": "https://api-inference.huggingface.co/models/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
