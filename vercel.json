{
  "buildCommand": "cd text-to-image-app && npm install && npm run build",
  "outputDirectory": "text-to-image-app/dist",
  "rewrites": [
    {
      "source": "/hf-api/:path*",
      "destination": "https://api-inference.huggingface.co/:path*"
    },
    {
      "source": "/hf-inference/:path*",
      "destination": "https://api-inference.huggingface.co/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
